{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "lib": ["ES2020"],
        "types": ["node", "@playwright/test"],
        "strict": false,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "outDir": "dist",
        "rootDir": ".",
        "skipLibCheck": true
    },
    "include": ["src/**/*.ts", "feature/**/*.ts"],
    "exclude": ["node_modules", "dist"]
}